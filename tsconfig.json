{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "types": ["node"]
  },
  "include": ["./bin", "./src"],
  "exclude": ["./dist"]
}
